{
  "name": "@nightcityverse/app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,client -c yellow,cyan \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite --port 5174",
    "build": "vite build",
    "start": "tsx server/index.ts"
  },
  "dependencies": {
    "@fastify/static": "^8",
    "fastify": "^5",
    "ws": "^8"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/ws": "^8",
    "concurrently": "^9",
    "tsx": "^4",
    "typescript": "^5",
    "vite": "^5"
  }
}
